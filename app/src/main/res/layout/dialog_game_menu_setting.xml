                        android:gravity="center"
                        android:padding="4dp"
                        android:id="@+id/rbt_game_setting_control_3"
                        android:button="@null"
                        android:text="@string/xml_dialog_game_menu_setting_19"
                        android:textSize="6dp" />

                    <RadioButton
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginRight="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/ic_game_menu_btn_selector"
                        android:gravity="center"
                        android:padding="4dp"
                        android:id="@+id/rbt_game_setting_control_4"
                        android:button="@null"
                        android:text="@string/xml_dialog_game_menu_setting_20"
                        android:textSize="6dp" />

                </RadioGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/xml_dialog_game_menu_setting_21"
                    android:textStyle="italic|bold"
                    android:textColor="@android:color/white"
                    android:textSize="8dp" />

                <RadioGroup
                    android:layout_width="match_parent"
                    android:layout_height="27dp"
                    android:layout_marginTop="4dp"
                    android:id="@+id/rg_game_setting_touch"
                    android:orientation="horizontal">

                    <RadioButton
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginRight="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/ic_game_menu_btn_selector"
                        android:gravity="center"
                        android:padding="4dp"
                        android:id="@+id/rbt_game_setting_touch_1"
                        android:button="@null"
                        android:text="@string/xml_dialog_game_menu_setting_17"
                        android:checked="true"
                        android:textSize="6dp" />

                    <RadioButton
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginRight="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/ic_game_menu_btn_selector"
                        android:gravity="center"
                        android:padding="4dp"
                        android:id="@+id/rbt_game_setting_touch_2"
                        android:button="@null"
                        android:text="@string/xml_dialog_game_menu_setting_23"
                        android:textSize="6dp" />

                    <RadioButton
