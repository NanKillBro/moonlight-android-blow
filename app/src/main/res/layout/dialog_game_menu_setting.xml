                        android:layout_height="match_parent"
                        android:layout_marginRight="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/ic_game_menu_btn_selector"
                        android:gravity="center"
                        android:padding="4dp"
                        android:button="@null"
                        android:id="@+id/btn_game_float_ball"
                        android:text="@string/xml_dialog_game_menu_setting_4"
                        android:textSize="8dp" />

<!--                    <CheckBox-->
<!--                        android:layout_width="match_parent"-->
<!--                        android:layout_height="match_parent"-->
<!--                        android:layout_marginRight="5dp"-->
<!--                        android:layout_weight="1"-->
<!--                        android:background="@drawable/ic_game_menu_btn_selector"-->
<!--                        android:gravity="center"-->
<!--                        android:padding="4dp"-->
<!--                        android:button="@null"-->
<!--                        android:id="@+id/btn_game_float_ball_quick"-->
<!--                        android:text="悬浮球\n打开软键盘"-->
<!--                        android:textSize="8dp" />-->

                    <CheckBox
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginRight="5dp"
