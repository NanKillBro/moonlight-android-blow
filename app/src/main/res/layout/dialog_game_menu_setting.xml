                        android:padding="4dp"
                        android:button="@null"
                        android:id="@+id/btn_game_force_gyro_switch"
                        android:text="@string/xml_dialog_game_menu_setting_32"
                        android:textSize="8dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/xml_dialog_game_menu_setting_33"
                    android:textStyle="italic|bold"
                    android:visibility="visible"
                    android:id="@+id/tx_game_setting_gyro_sensitivity"
                    android:textColor="@android:color/white"
                    android:textSize="8dp" />

                <SeekBar
                    android:max="200"
                    android:min="50"
                    android:layout_marginTop="4dp"
                    android:layout_marginRight="5dp"
                    android:padding="0dp"
                    android:thumbOffset="0dp"
                    android:progress="100"
                    android:splitTrack="false"
                    android:id="@+id/sb_game_setting_gyro_sensitivity"
                    android:thumb="@android:color/transparent"
                    android:progressDrawable="@drawable/ic_game_menu_seek_bg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="性能信息 缩放：100%"
                    android:textStyle="italic|bold"
                    android:visibility="visible"
                    android:id="@+id/tx_game_setting_pref_zoom"
                    android:textColor="@android:color/white"
                    android:textSize="8dp" />

                <SeekBar
                    android:max="230"
                    android:min="50"
                    android:layout_marginTop="4dp"
                    android:layout_marginRight="5dp"
                    android:padding="0dp"
                    android:thumbOffset="0dp"
                    android:progress="100"
                    android:splitTrack="false"
                    android:id="@+id/sb_game_setting_pref_zoom"
                    android:thumb="@android:color/transparent"
                    android:progressDrawable="@drawable/ic_game_menu_seek_bg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="性能信息 边距：4"
