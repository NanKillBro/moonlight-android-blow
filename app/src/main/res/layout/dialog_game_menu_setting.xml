                <SeekBar
                    android:max="100"
                    android:min="0"
                    android:layout_marginTop="4dp"
                    android:layout_marginRight="5dp"
                    android:padding="0dp"
                    android:thumbOffset="0dp"
                    android:progress="4"
                    android:splitTrack="false"
                    android:id="@+id/sb_game_setting_pref_magin_top"
                    android:thumb="@android:color/transparent"
                    android:progressDrawable="@drawable/ic_game_menu_seek_bg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/xml_dialog_game_menu_setting_36"
                        android:textStyle="italic|bold"
                        android:textColor="@android:color/white"
                        android:textSize="8dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        android:text="@string/xml_dialog_game_menu_setting_37"
                        android:textStyle="italic|bold"
                        android:textColor="#FFC107"
                        android:textSize="6dp" />
                </LinearLayout>

                <RadioGroup
